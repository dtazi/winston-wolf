# Copy to .env and fill in your real keys. .env is gitignored.

# Search vendors
EXA_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPER_API_KEY=
PERPLEXITY_API_KEY=

# LLM provider for Pattern D (ICP extraction from URL).
# We shell out to `claude -p`, authenticated via the user's Max subscription.
# To set this up: run `claude setup-token` on a machine with a browser, paste
# the resulting long-lived token below. The token persists across the harness
# and is inherited by every `claude` subprocess the runner spawns.
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative path (not used by default): direct Anthropic API billing.
# If set, a future ClaudeAPIExtractor can use this instead of subprocess.
ANTHROPIC_API_KEY=

# Email-finding vendors (Pattern E)
HUNTER_API_KEY=
APOLLO_API_KEY=
